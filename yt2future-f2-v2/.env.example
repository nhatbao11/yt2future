# Copy to .env.local — không commit file có secret
NEXT_PUBLIC_SITE_URL=https://yt2future.com
NEXT_PUBLIC_BE_URL=http://localhost:5000
# Bỏ trống hoặc dùng /api: client gọi cùng origin (cookie đăng nhập gửi được). Chỉ set URL BE đầy đủ nếu bạn chủ động cấu hình CORS + cookie cross-origin.
# NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SEO: không index bản EN (true/false)
SEO_NOINDEX_EN=false
