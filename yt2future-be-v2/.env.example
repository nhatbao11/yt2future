PORT=5000
NODE_ENV=development
# Phân tách bằng dấu phẩy — FE production + localhost dev
CORS_ORIGINS=https://yt2future.com,https://www.yt2future.com,http://localhost:3000,http://127.0.0.1:3000
# Nếu dùng Supabase session mode, thêm `connection_limit=1` để tránh lỗi "max clients reached"
# Ví dụ: postgresql://user:pass@host:6543/postgres?pgbouncer=true&connection_limit=1
DATABASE_URL=postgresql://yt2future:yt2future@localhost:5432/yt2future
JWT_SECRET=change-me-in-production
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
LOCAL_API_URL=http://localhost:5000/api
FINFO_API_BASE_URL=https://finfo-api.vndirect.com.vn
SYNC_BOOTSTRAP_YEARS=5
VN_MARKET_HOLIDAYS=
